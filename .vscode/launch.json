    "version": "0.2.0",
    "configurations": [
        {
            "name": "YIER",
            "type": "debugpy",
            "request": "launch",
            "module": "granian",
            "args": [
                "--interface",
                "asgi",
                "main:build_app",
                "--factory",
                "--host",
                "0.0.0.0",
                "--port",
                "9999",
                "--reload",
                "--reload-ignore-dirs",
